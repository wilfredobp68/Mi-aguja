# ─────────────────────────────────────────────────────────────
# Archivo de ejemplo de configuración.
# Copia este archivo como ".env" si quieres cambiar algún valor.
# Si NO creas un .env, el backend usa estos mismos valores por defecto.
# ─────────────────────────────────────────────────────────────

# Base de datos (SQLite por defecto = un archivo local).
DATABASE_URL=sqlite:///./mi_aguja.db

# Clave para firmar los tokens. EN PRODUCCIÓN cámbiala por una larga y aleatoria.
SECRET_KEY=cambia-esta-clave-secreta-por-una-larga-y-aleatoria

# Cuánto dura la sesión, en minutos (1440 = 24 horas).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Direcciones del frontend autorizadas (separadas por comas).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
